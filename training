        const daysOfWeek = ['Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота', 'Воскресенье'];

        class ScheduleGenerator {
            constructor(goal, daysCount, level, duration) {
                this.goal = goal;
                this.daysCount = parseInt(daysCount);
                this.level = level;
                this.duration = duration;
                this.schedule = [];
            }

            generate() {
                const trainingDays = this.selectTrainingDays();
                this.schedule = daysOfWeek.map((day, index) => {
                    const isTrainingDay = trainingDays.includes(index);
                    if (!isTrainingDay) {
                        return { day, type: 'rest', exercises: null };
                    }
                    
                    const workoutType = this.getWorkoutType(index);
                    const exercises = this.getExercises(workoutType);
                    
                    return {
                        day,
                        type: 'training',
                        workoutType,
                        exercises,
                        duration: this.duration
                    };
                });
                
                return this.schedule;
            }

            selectTrainingDays() {
                const totalDays = this.daysCount;
                const indices = [];
                
                // Распределяем тренировки равномерно по неделе
                if (totalDays === 3) {
                    indices.push(0, 2, 4); // ПН, СР, ПТ
                } else if (totalDays === 4) {
                    indices.push(0, 1, 3, 5); // ПН, ВТ, ЧТ, СБ
                } else if (totalDays === 5) {
                    indices.push(0, 1, 2, 3, 5); // ПН-ЧТ, СБ
                } else if (totalDays === 6) {
                    indices.push(0, 1, 2, 3, 4, 5); // ПН-СБ
                }
                
                return indices;
            }

            getWorkoutType(dayIndex) {
                const trainingPattern = [
                    'upper', 'lower', 'full', 'upper', 'lower', 'full', 'full'
                ];
                return trainingPattern[dayIndex % trainingPattern.length];
            }

            getExercises(workoutType) {
                const db = exerciseDatabase[this.goal];
                if (!db || !db[this.level] || !db[this.level][workoutType]) {
                    return this.getFallbackExercises(workoutType);
                }
                
                const exercises = db[this.level][workoutType];
                // Возвращаем первые 3-6 упражнений в зависимости от уровня
                const count = this.level === 'beginner' ? 4 : (this.level === 'intermediate' ? 5 : 6);
                return exercises.slice(0, count);
            }

            getFallbackExercises(workoutType) {
                return [
                    { name: "Отжимания", icon: "💪", sets: "3", reps: "10-12" },
                    { name: "Приседания", icon: "🦵", sets: "3", reps: "12-15" },
                    { name: "Планка", icon: "", duration: "60 сек" }
                ];
            }
        }

