                    day.exercises.forEach(exercise => {
                        const item = document.createElement('li');
                        item.className = 'exercise-item';
                        
                        const icon = document.createElement('span');
                        icon.className = 'exercise-icon';
                        icon.textContent = exercise.icon || '💪';
                        
                        const nameSpan = document.createElement('span');
                        nameSpan.className = 'exercise-name';
                        nameSpan.textContent = exercise.name;
                        
                        const detailsSpan = document.createElement('span');
                        detailsSpan.className = 'exercise-details';
                        
                        if (exercise.sets) {
                            detailsSpan.textContent = `${exercise.sets} × ${exercise.reps} | отдых ${exercise.rest || '60'}`;
                        } else if (exercise.duration) {
                            detailsSpan.textContent = `${exercise.duration} | ${exercise.intensity || 'Средний'} темп`;
                        } else {
                            detailsSpan.textContent = 'Следуйте технике выполнения';
                        }
                        
                        item.appendChild(icon);
                        item.appendChild(nameSpan);
                        item.appendChild(detailsSpan);
                        exerciseList.appendChild(item);
                    });
                    
                    dayCard.appendChild(exerciseList);
                }
                
                weekGrid.appendChild(dayCard);
            });
            
            container.innerHTML = '';
            container.appendChild(weekGrid);
        }

        function exportToPDF() {
            const element = document.getElementById('scheduleContent');
            const opt = {
                margin: [0.5, 0.5, 0.5, 0.5],
                filename: 'gym_schedule.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
            };
            html2pdf().set(opt).from(element).save();
        }

        function exportToJSON(schedule) {
            const dataStr = JSON.stringify(schedule, null, 2);
            const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
            const exportFileDefaultName = 'gym_schedule.json';
            const linkElement = document.createElement('a');
            linkElement.setAttribute('href', dataUri);
            linkElement.setAttribute('download', exportFileDefaultName);
            linkElement.click();
        }

        document.getElementById('scheduleForm').addEventListener('submit', (e) => {
            e.preventDefault();
            
            const goal = document.getElementById('goal').value;
            const daysCount = document.getElementById('daysCount').value;
            const level = document.getElementById('level').value;
            const duration = document.getElementById('duration').value;
            
            const generator = new ScheduleGenerator(goal, daysCount, level, duration);
            const schedule = generator.generate();
            
            renderSchedule(schedule);
            
            window.currentSchedule = schedule;
        });
        
        document.getElementById('exportPdf').addEventListener('click', () => {
            if (window.currentSchedule) {
                exportToPDF();
            } else {
                alert('Сначала сгенерируйте расписание');
            }
        });
        
        document.getElementById('exportJson').addEventListener('click', () => {
            if (window.currentSchedule) {
                exportToJSON(window.currentSchedule);
            } else {
                alert('Сначала сгенерируйте расписание');
            }
        });
        
        // Генерируем расписание по умолчанию при загрузке
        setTimeout(() => {
            const defaultGenerator = new ScheduleGenerator('strength', '4', 'intermediate', '60');
            const defaultSchedule = defaultGenerator.generate();
            renderSchedule(defaultSchedule);
            window.currentSchedule = defaultSchedule;
        }, 100);
    </script>
</body>
</html>
